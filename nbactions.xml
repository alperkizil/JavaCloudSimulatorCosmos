<?xml version="1.0" encoding="UTF-8"?>
<actions>
    <!-- Project Run (F6) - launches the JavaFX GUI -->
    <action>
        <actionName>run</actionName>
        <packagings>
            <packaging>jar</packaging>
        </packagings>
        <goals>
            <goal>clean</goal>
            <goal>javafx:run</goal>
        </goals>
    </action>

    <!-- Project Debug - launches the JavaFX GUI with debugger -->
    <action>
        <actionName>debug</actionName>
        <packagings>
            <packaging>jar</packaging>
        </packagings>
        <goals>
            <goal>clean</goal>
            <goal>javafx:run</goal>
        </goals>
        <properties>
            <jpda.listen>true</jpda.listen>
        </properties>
    </action>

    <!-- Run Single File (Shift+F6) - runs any class with main method -->
    <!-- Uses test classpath to include both main and test classes -->
    <action>
        <actionName>run.single.main</actionName>
        <packagings>
            <packaging>jar</packaging>
        </packagings>
        <goals>
            <goal>process-test-classes</goal>
            <goal>org.codehaus.mojo:exec-maven-plugin:3.1.0:java</goal>
        </goals>
        <properties>
            <exec.mainClass>${packageClassName}</exec.mainClass>
            <exec.classpathScope>test</exec.classpathScope>
        </properties>
    </action>

    <!-- Debug Single File - debug any class with main method -->
    <action>
        <actionName>debug.single.main</actionName>
        <packagings>
            <packaging>jar</packaging>
        </packagings>
        <goals>
            <goal>process-test-classes</goal>
            <goal>org.codehaus.mojo:exec-maven-plugin:3.1.0:exec</goal>
        </goals>
        <properties>
            <exec.executable>java</exec.executable>
            <exec.classpathScope>test</exec.classpathScope>
            <exec.args>-agentlib:jdwp=transport=dt_socket,server=n,address=${jpda.address} -classpath %classpath ${packageClassName}</exec.args>
            <jpda.listen>true</jpda.listen>
        </properties>
    </action>
</actions>
